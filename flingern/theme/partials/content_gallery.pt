<div id="page">
    <h1>${page.title}</h1>
    <div id="content" tal:content="structure page.content">
    </div>
    <div tal:repeat="gallery page.galleries" class="gallery-images d-none" data-gallery="${gallery.name}">
        <a tal:repeat="img gallery.images" href="${site.url}/${img.path}" data-toggle="lightbox" data-gallery="${gallery.name}" data-thumb-height="${img.thumb_height}">
            <img src="${site.url}/${img.thumb}" class="img-fluid img-item" alt="...">
        </a>
    </div>
</div>
